DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/dbname

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

SECRET_KEY=your_secret_key # Генерация секретного ключа для JWT: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DEBUG=False

GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

KAFKA_URL=kafka:9092
KAFKA_ACKS=all
KAFKA_ENABLE_IDEMPOTENCE=True
KAFKA_CONSUMER_GROUP=users-events-group

USER_EVENTS_TOPIC=user.events

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password
REDIS_TTL=3600
